# ==========================================
# Orch — environment configuration
# Copy to .env and adjust. NEVER commit real secrets.
# ==========================================
#
# Running the full stack with Docker (`docker compose up --build`) needs almost
# nothing here — only JWT_SECRET is read from this file; the rest is wired up in
# docker-compose.yml. The values below are for running the apps directly on your
# host during development (`pnpm start:infra` + `pnpm --filter orch-web dev` and
# `cargo run`), where services talk to each other over localhost.

# ── Shared ──
# Secret used to sign/verify JWTs. MUST be identical for web and broker.
JWT_SECRET=change-me-in-production

# ── Orch Web (apps/web) ──
# PostgreSQL — the compose Postgres is published on host port 5447.
DATABASE_URL=postgresql://postgres:postgres@localhost:5447/orchiodb
# Where the web app reaches the broker.
ORCH_BROKER_URL=http://localhost:8047
# Kafka — use the EXTERNAL listener published on host port 29092.
KAFKA_BROKERS=localhost:29092
# Base path the UI and API are served under.
NEXT_PUBLIC_API_BASE_URL=/orch/api

# ── Orch Broker (apps/orch-broker) ──
PORT=8047
RUST_LOG=info
# Where the broker reaches the web app's config API (include the /orch base path).
API_BASE_URL=http://localhost:3047/orch
DATABASE_URL=postgresql://postgres:postgres@localhost:5447/orchiodb
KAFKA_BROKERS=localhost:29092
# Optional shared secret. If set on BOTH web and broker, internal service-to-service
# calls are authenticated via the X-Internal-Token header.
# INTERNAL_API_TOKEN=

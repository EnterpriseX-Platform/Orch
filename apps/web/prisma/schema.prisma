// ==================== SYSTEM CONFIGURATION ====================
// Admin-editable runtime configuration. Replaces env vars for values
// that should be changeable without a redeploy (backend URLs, feature
// flags, audit policy, alert thresholds, etc.). Secrets still live in
// env / K8s secrets — do NOT store passwords or API keys here.
model SystemConfig {
  id        String          @id @default(cuid())
  key       String // dotted path e.g. "orchBroker.url"
  value     Json // actual value (string/number/bool/object)
  valueType ConfigValueType @default(STRING) @map("value_type")
  category  ConfigCategory  @default(GENERAL)

  // Display
  label       String? // human-readable label
  description String? // longer help text
  group       String? // sub-group e.g. "APP-A"

  // Validation / flags
  isSecret     Boolean @default(false) @map("is_secret") // mask in UI/API
  isRequired   Boolean @default(false) @map("is_required")
  isReadOnly   Boolean @default(false) @map("is_read_only") // system-managed
  validation   Json? // { pattern, min, max, enum[] }
  defaultValue Json?   @map("default_value")

  // Scoping — null projectId = global, else project override
  projectId String? @map("project_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")


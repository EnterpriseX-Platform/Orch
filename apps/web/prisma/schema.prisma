// ==================== API LOGS / AUDIT TRAIL ====================
model ApiLog {
  id String @id @default(cuid())

  // Request Info
  requestId String @unique @map("request_id")
  // Logs reference the API by id but with NO foreign key constraint:
  // logs are append-only history that must outlive the source API
  // (retention ≥ 365 days). FK would also block API delete
  // and slow down inserts on every request. apiId is still indexed
  // for query joins; orphaned rows after API delete are intentional
  // and queryable.
  apiId     String @map("api_id")

  // User Info
  userId    String? @map("user_id")
  userIp    String? @map("user_ip")
  userAgent String? @map("user_agent")

  // Request Details
  method         String
  path           String
  queryParams    Json?  @map("query_params")
  requestHeaders Json?  @map("request_headers")
  requestBody    Json?  @map("request_body")

  // Response Details
  statusCode      Int   @map("status_code")
  responseHeaders Json? @map("response_headers")
  responseBody    Json? @map("response_body")

  // Performance
  duration Int // milliseconds

  // Extracted Data (from XPath/JSONPath)
  extractedData Json? @map("extracted_data")

  // Timestamp
  timestamp DateTime @default(now())

  // Partition key for archiving
  partitionKey String @default(dbgenerated("to_char(now(), 'YYYYMM')")) @map("partition_key")

  @@index([apiId, timestamp])
  @@index([userId, timestamp])
  @@index([partitionKey])
  @@index([timestamp])
  @@map("api_logs")
}

// ==================== EVENT LOG PATTERNS ====================
//
// Admins describe URL patterns they want to capture into event_logs
// without registering the path as a full ApiRegistration. Used for
// observability ("log me every /payments/* call") rather than
// audit ("record what changed").
//
// Match contract: pathPattern + methodMatch must hold; if bodyMatch
// is set, every entry there must hold too (same shape as
// MessageFormat.matchRules — JSONPath-ish field, expected value).
//
// On match the gateway writes an EventLog row whose `data` payload
// depends on `capture`:
//   SUMMARY   { method, path, status, duration }
//   FULL_BODY SUMMARY + request body + response body
//   NONE      no row written, but `level=warn` rules can still
//             surface in dashboards as a "saw it pass through" mark
//
model EventLogPattern {
  id String @id @default(cuid())

  // Scope. Null = global (matches every project's traffic).
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String // human label
  description String?
  pathPattern String          @map("path_pattern") // /app-a/microflow/* | /payments/:id
  methodMatch String          @default("ANY") @map("method_match") // ANY | GET | POST | …
  // Optional AND-rules (BODY/HEADER) — same shape as
  // MessageFormat.matchRules so admins reuse the same mental model.
  bodyMatch   Json?           @map("body_match")
  capture     EventLogCapture @default(SUMMARY)
  level       String          @default("info") // info | warn | error
  enabled     Boolean         @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, enabled])
  @@map("event_log_patterns")
}

enum EventLogCapture {
  SUMMARY
  FULL_BODY
  NONE

  @@map("event_log_capture")
}


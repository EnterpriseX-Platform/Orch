  executionStrategy String @default("fast") @map("execution_strategy")

  // NEW: Custom Queue Configuration (for executionStrategy = "custom")
  // { "type": "kafka" | "rabbitmq" | "sqs", "config": {...} }
  customQueueConfig Json? @map("custom_queue_config")

  // Flow Configuration (ReactFlow format)

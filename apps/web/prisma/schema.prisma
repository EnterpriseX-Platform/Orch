// ──────────────── DATA REPOSITORY ────────────────
// Catalog of physical tables managed by Orch. Each table holds
// "transactional" data (orders, line items, payments, ...) and gets
// CRUD APIs auto-published. Tables can be column-encrypted via the
// existing engine-aware DDL generator.
//
// Design notes:
//   - RepoTable.name maps 1:1 to a real Postgres/Oracle table that
//     Orch owns (under the `repo_*` prefix to avoid collision).
//   - schemaJson stores [{name,type,nullable,encrypted}] used both
//     for UI rendering and DDL generation.
//   - apiKey access is gated by RepoApiKey (separate from project keys).

model RepoFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   RepoFolder?  @relation("RepoFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children RepoFolder[] @relation("RepoFolderTree")
  tables   RepoTable[]

  @@index([parentId])
  @@map("repo_folders")
}

model RepoTable {
  id                String       @id @default(cuid())
  name              String       @unique // physical table name (becomes repo_<name>)
  displayName       String?      @map("display_name") // friendly label
  description       String?
  category          DataCategory @default(OTHER) // reuse the existing enum
  folderId          String?      @map("folder_id")
  // Source connection — when set, this RepoTable points at a real
  // table living in an external Postgres/MySQL/Oracle. When NULL,
  // the table lives in Orch's own DB (prefix `repo_<name>`).
  connectionId      String?      @map("connection_id")
  // The actual table name in the external DB — only used when
  // connectionId is set. For Orch-owned tables we always use
  // physicalTableName(name) = `repo_<name>`.
  externalTableName String?      @map("external_table_name")
  sortOrder         Int          @default(0) @map("sort_order")
  // [{name,type,nullable,encrypted}] — what columns the physical
  // table has. Updated by /tables/:id/structure DDL operations.
  schemaJson        Json         @default("[]") @map("schema_json")
  rowCount          Int          @default(0) @map("row_count")
  // last time we ran ALTER TABLE / DDL for this table
  lastAlterAt       DateTime?    @map("last_alter_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  folder     RepoFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  connection RepoConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([category])
  @@index([connectionId])
  @@map("repo_tables")
}

// API key for external access to data-repository CRUD APIs.
// Different from project-level ApiKey; scoped only to /api/repo/*.
model RepoApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique @map("key_hash") // hash of the key (never store plain)
  keyPrefix   String    @map("key_prefix") // first 8 chars for display
  permissions String    @default("read") // read | write | admin
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("repo_api_keys")
}

// External database connections that the data-repository can browse,
// import from, or proxy CRUD against. Mirrors a typical integration
// platform so admins migrating between the two systems see the same
// affordances.
//
// `config` is JSON: { host, port, database, username, password, ssl }
// — kept as Json so we can add per-engine knobs later without
// migrating again.
model RepoConnection {
  id           String    @id @default(cuid())
  name         String
  type         String // postgresql | mysql | oracle
  config       Json      @default("{}")
  status       String    @default("Disconnected") // Connected | Disconnected | Error
  lastTestedAt DateTime? @map("last_tested_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tables RepoTable[]

  @@map("repo_connections")
}

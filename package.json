{
  "name": "orch",
  "version": "1.0.0",
  "private": true,
  "description": "Orch Platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=orch-web",
    "dev:broker": "turbo run dev --filter=orch-broker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "cd apps/web && npx prisma migrate deploy",
    "db:generate": "cd apps/web && npx prisma generate",
    "db:studio": "cd apps/web && npx prisma studio",
    "start:infra": "docker compose up -d postgres kafka zookeeper kafka-ui",
    "stop:infra": "docker compose down",
    "start": "docker compose up --build -d",
    "stop": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
